rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function isAdmin() {
      return (request.auth != null && (
        request.auth.token.email.lower() == 'pankaj.ydv707@gmail.com'
      ));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users Collection
    match /users/{userId} {
      allow get: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (request.auth != null && request.auth.uid == userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update: if (request.auth != null && request.auth.uid == userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if request.auth != null
        && incoming().stock is number
        && incoming().stock >= 0
        && incoming().price == existing().price
        && incoming().name == existing().name;
    }

    // COAS Collection
    match /coas/{coaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      // Public read by exact Order ID for tracking
      allow get: if isValidId(orderId);

      // List only for admin or matching customer
      allow list: if isAdmin();

      // Anyone can create an order (guests or logged-in users)
      // isAdmin() bypass ensures dev/test always works
      allow create: if isAdmin() || (
        isValidId(orderId) &&
        incoming().order_id == orderId &&
        incoming().keys().hasAll([
          'order_id', 'customer_name', 'customer_email', 'customer_phone',
          'shipping_address', 'city', 'delivery_method', 'payment_method',
          'payment_proof', 'items', 'subtotal', 'shipping_fee', 'total_amount',
          'status', 'created_at', 'updated_at'
        ]) &&
        incoming().delivery_method in ['Lalamove', 'GrabExpress'] &&
        incoming().payment_method == 'GCash' &&
        incoming().status == 'Pending' &&
        incoming().created_at == request.time &&
        incoming().updated_at == request.time
      );

      // Admin-only updates for status changes
      allow update: if isAdmin() && (
        incoming().status in ['Pending', 'Confirmed', 'Shipped'] &&
        incoming().updated_at == request.time &&
        incoming().order_id == existing().order_id &&
        incoming().customer_email == existing().customer_email &&
        incoming().total_amount == existing().total_amount &&
        incoming().created_at == existing().created_at
      );

      allow delete: if false;

      // Status History Subcollection
      match /status_history/{historyId} {
        allow read: if isValidId(orderId) && isValidId(historyId);

        // Admin or customer creating the initial Pending entry
        allow create: if isValidId(historyId) &&
          incoming().keys().hasAll(['status', 'updated_by', 'created_at']) &&
          incoming().keys().size() == 3 &&
          incoming().status in ['Pending', 'Confirmed', 'Shipped'] &&
          incoming().created_at == request.time &&
          (isAdmin() || (
            incoming().status == 'Pending' &&
            incoming().updated_by == getAfter(/databases/$(database)/documents/orders/$(orderId)).data.customer_email
          ));

        allow update, delete: if false;
      }
    }
  }
}
